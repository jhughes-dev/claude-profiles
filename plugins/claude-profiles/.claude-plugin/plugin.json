{
  "name": "claude-profiles",
  "version": "1.3.0",
  "description": "Manage per-workspace .claude profiles backed by a git repo of profile branches.",
  "author": {
    "name": "Jeremy Hughes",
    "url": "https://github.com/jhughes-dev"
  },
  "homepage": "https://github.com/jhughes-dev/claude-profiles",
  "repository": "https://github.com/jhughes-dev/claude-profiles.git",
  "license": "MIT",
  "keywords": ["profiles", "workspace", "git", "configuration"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "user_settings|project_settings|local_settings|skills",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/config-change.sh\""
          }
        ]
      }
    ]
  }
}
